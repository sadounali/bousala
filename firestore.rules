rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation
    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string 
        && data.email.size() <= 100
        && data.createdAt is string;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isSignedIn() && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'preferences']);
    }

    // Analysis History Validation
    function isValidAnalysis(data) {
      return data.userId == request.auth.uid
        && data.fileName is string && data.fileName.size() <= 255
        && (data.timestamp == request.time || data.timestamp is string)
        && data.result is map
        && data.result.overallScore is number;
    }

    // Test Connection
    match /test/connection {
      allow read: if true;
    }

    match /analysisHistory/{analysisId} {
      allow read, write: if true;
    }

    // Student Profile & Thesis Rules
    match /students/{userId} {
      allow read, write: if true;
    }

    match /theses/{userId} {
      allow read, write: if true;
    }
  }
}
